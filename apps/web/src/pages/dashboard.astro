---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
---

<Layout title="Dashboard - Duckmetric" hideHeader>
  <Sidebar />

  <div id="dashboard-content" class="hidden ml-[18rem]">
    <!-- Header -->
    <header class="flex h-12 shrink-0 items-center gap-2 border-b border-neutral-800 px-4">
      <h1 class="text-sm font-medium text-white">Dashboard</h1>
    </header>

    <div class="flex flex-1 flex-col">
      <div class="flex flex-1 flex-col gap-2">
        <div class="flex flex-col gap-4 py-4 md:gap-6 md:py-6">
          <!-- Section Cards -->
          <div class="grid gap-4 px-4 sm:grid-cols-2 lg:grid-cols-4 lg:px-6">
            <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-4">
              <p class="text-sm text-neutral-400">Total Revenue</p>
              <p class="text-2xl font-bold text-white">$1,250.00</p>
              <p class="text-xs text-emerald-500">+12.5% from last month</p>
            </div>
            <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-4">
              <p class="text-sm text-neutral-400">New Customers</p>
              <p class="text-2xl font-bold text-white">1,234</p>
              <p class="text-xs text-red-500">-20% from last month</p>
            </div>
            <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-4">
              <p class="text-sm text-neutral-400">Active Accounts</p>
              <p class="text-2xl font-bold text-white">45,678</p>
              <p class="text-xs text-emerald-500">+12.5% from last month</p>
            </div>
            <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-4">
              <p class="text-sm text-neutral-400">Growth Rate</p>
              <p class="text-2xl font-bold text-white">4.5%</p>
              <p class="text-xs text-emerald-500">+4.5% from last month</p>
            </div>
          </div>

          <!-- Chart Placeholder -->
          <div class="px-4 lg:px-6">
            <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-6">
              <h3 class="text-lg font-semibold text-white mb-4">Total Visitors</h3>
              <p class="text-sm text-neutral-400 mb-4">Total for the last 3 months</p>
              <div class="h-[250px] flex items-center justify-center border border-dashed border-neutral-700 rounded-lg">
                <p class="text-sm text-neutral-500">Chart will be rendered here</p>
              </div>
            </div>
          </div>

          <!-- Data Table -->
          <div class="px-4 lg:px-6">
            <div class="rounded-xl border border-neutral-800 bg-neutral-900/50">
              <div class="p-4 border-b border-neutral-800">
                <h3 class="text-lg font-semibold text-white">Recent Activity</h3>
                <p class="text-sm text-neutral-400">Your recent transactions and updates</p>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full">
                  <thead>
                    <tr class="border-b border-neutral-800">
                      <th class="px-4 py-3 text-left text-xs font-medium text-neutral-400 uppercase">Name</th>
                      <th class="px-4 py-3 text-left text-xs font-medium text-neutral-400 uppercase">Status</th>
                      <th class="px-4 py-3 text-left text-xs font-medium text-neutral-400 uppercase">Date</th>
                      <th class="px-4 py-3 text-left text-xs font-medium text-neutral-400 uppercase">Amount</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="border-b border-neutral-800/50 hover:bg-neutral-800/30">
                      <td class="px-4 py-3 text-sm text-white">Invoice #1234</td>
                      <td class="px-4 py-3"><span class="inline-flex items-center rounded-full bg-emerald-500/10 px-2 py-1 text-xs font-medium text-emerald-500">Paid</span></td>
                      <td class="px-4 py-3 text-sm text-neutral-400">Jun 23, 2026</td>
                      <td class="px-4 py-3 text-sm text-white">$250.00</td>
                    </tr>
                    <tr class="border-b border-neutral-800/50 hover:bg-neutral-800/30">
                      <td class="px-4 py-3 text-sm text-white">Invoice #1233</td>
                      <td class="px-4 py-3"><span class="inline-flex items-center rounded-full bg-yellow-500/10 px-2 py-1 text-xs font-medium text-yellow-500">Pending</span></td>
                      <td class="px-4 py-3 text-sm text-neutral-400">Jun 22, 2026</td>
                      <td class="px-4 py-3 text-sm text-white">$180.00</td>
                    </tr>
                    <tr class="border-b border-neutral-800/50 hover:bg-neutral-800/30">
                      <td class="px-4 py-3 text-sm text-white">Invoice #1232</td>
                      <td class="px-4 py-3"><span class="inline-flex items-center rounded-full bg-emerald-500/10 px-2 py-1 text-xs font-medium text-emerald-500">Paid</span></td>
                      <td class="px-4 py-3 text-sm text-neutral-400">Jun 21, 2026</td>
                      <td class="px-4 py-3 text-sm text-white">$320.00</td>
                    </tr>
                    <tr class="hover:bg-neutral-800/30">
                      <td class="px-4 py-3 text-sm text-white">Invoice #1231</td>
                      <td class="px-4 py-3"><span class="inline-flex items-center rounded-full bg-red-500/10 px-2 py-1 text-xs font-medium text-red-500">Overdue</span></td>
                      <td class="px-4 py-3 text-sm text-neutral-400">Jun 20, 2026</td>
                      <td class="px-4 py-3 text-sm text-white">$420.00</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="loading" class="flex h-screen items-center justify-center ml-[18rem]">
    <div class="flex flex-col items-center gap-3">
      <div class="h-8 w-8 animate-spin rounded-full border-2 border-emerald-500 border-t-transparent"></div>
      <p class="text-sm text-neutral-400">Loading...</p>
    </div>
  </div>

  <div id="redirect" class="hidden flex h-screen items-center justify-center ml-[18rem]">
    <div class="flex flex-col items-center gap-3">
      <div class="h-8 w-8 animate-spin rounded-full border-2 border-emerald-500 border-t-transparent"></div>
      <p class="text-sm text-neutral-400">Redirecting to login...</p>
    </div>
  </div>
</Layout>

<script>
  import { authClient } from "../lib/auth-client";
  import { orpc } from "../lib/orpc";

  const dashboardContent = document.getElementById("dashboard-content")!;
  const loading = document.getElementById("loading")!;
  const redirect = document.getElementById("redirect")!;
  const statusDot = document.getElementById("status-dot");
  const statusText = document.getElementById("status-text");

  async function init() {
    try {
      const { data: session } = await authClient.getSession();

      if (!session?.user) {
        loading.classList.add("hidden");
        redirect.classList.remove("hidden");
        window.location.href = "/login";
        return;
      }

      try {
        await orpc.healthCheck();
      } catch {
        // API not connected
      }

      loading.classList.add("hidden");
      dashboardContent.classList.remove("hidden");
    } catch {
      loading.classList.add("hidden");
      redirect.classList.remove("hidden");
      window.location.href = "/login";
    }
  }

  init();
</script>
