---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
---

<Layout title="Dashboard - Duckmetric" hideHeader>
  <Sidebar />

  <div id="dashboard-content" class="hidden ml-[16rem]">
    <main class="px-4 py-12">
      <div class="rounded-xl border border-neutral-800 bg-neutral-900/50 p-8">
        <div class="flex items-center gap-4 mb-8">
          <div id="user-avatar" class="flex h-12 w-12 items-center justify-center rounded-full bg-emerald-500/20 text-emerald-500 font-semibold text-lg"></div>
          <div>
            <h1 class="text-2xl font-bold text-white" id="user-name">Loading...</h1>
            <p class="text-sm text-neutral-400" id="user-email">Loading...</p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-neutral-800 bg-neutral-800/30 p-5">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10">
                <svg class="h-4 w-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-sm font-medium text-white">Account Status</h3>
            </div>
            <p class="text-sm text-neutral-400">Your account is active and verified</p>
          </div>

          <div class="rounded-lg border border-neutral-800 bg-neutral-800/30 p-5">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-blue-500/10">
                <svg class="h-4 w-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-sm font-medium text-white">Last Login</h3>
            </div>
            <p class="text-sm text-neutral-400" id="last-login">Just now</p>
          </div>

          <div class="rounded-lg border border-neutral-800 bg-neutral-800/30 p-5">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-purple-500/10">
                <svg class="h-4 w-4 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                </svg>
              </div>
              <h3 class="text-sm font-medium text-white">Security</h3>
            </div>
            <p class="text-sm text-neutral-400">Email verified, sessions active</p>
          </div>

          <div class="rounded-lg border border-neutral-800 bg-neutral-800/30 p-5">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-orange-500/10">
                <svg class="h-4 w-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="text-sm font-medium text-white">API Status</h3>
            </div>
            <div class="flex items-center gap-2">
              <div class="h-2 w-2 rounded-full bg-green-500" id="status-dot"></div>
              <p class="text-sm text-neutral-400" id="status-text">Checking...</p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <div id="loading" class="flex h-screen items-center justify-center ml-[16rem]">
    <div class="flex flex-col items-center gap-3">
      <div class="h-8 w-8 animate-spin rounded-full border-2 border-emerald-500 border-t-transparent"></div>
      <p class="text-sm text-neutral-400">Loading...</p>
    </div>
  </div>

  <div id="redirect" class="hidden flex h-screen items-center justify-center ml-[16rem]">
    <div class="flex flex-col items-center gap-3">
      <div class="h-8 w-8 animate-spin rounded-full border-2 border-emerald-500 border-t-transparent"></div>
      <p class="text-sm text-neutral-400">Redirecting to login...</p>
    </div>
  </div>
</Layout>

<script>
  import { authClient } from "../lib/auth-client";
  import { orpc } from "../lib/orpc";

  const dashboardContent = document.getElementById("dashboard-content")!;
  const loading = document.getElementById("loading")!;
  const redirect = document.getElementById("redirect")!;
  const userName = document.getElementById("user-name")!;
  const userEmail = document.getElementById("user-email")!;
  const userAvatar = document.getElementById("user-avatar")!;
  const lastLogin = document.getElementById("last-login")!;
  const statusDot = document.getElementById("status-dot")!;
  const statusText = document.getElementById("status-text")!;

  async function init() {
    try {
      const { data: session } = await authClient.getSession();

      if (!session?.user) {
        loading.classList.add("hidden");
        redirect.classList.remove("hidden");
        window.location.href = "/login";
        return;
      }

      userName.textContent = session.user.name || "User";
      userEmail.textContent = session.user.email || "";
      userAvatar.textContent = (session.user.name || "U").charAt(0).toUpperCase();
      lastLogin.textContent = new Date().toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
      });

      try {
        await orpc.healthCheck();
        statusDot.className = "h-2 w-2 rounded-full bg-green-500";
        statusText.textContent = "Connected";
      } catch {
        statusDot.className = "h-2 w-2 rounded-full bg-red-500";
        statusText.textContent = "Disconnected";
      }

      loading.classList.add("hidden");
      dashboardContent.classList.remove("hidden");
    } catch {
      loading.classList.add("hidden");
      redirect.classList.remove("hidden");
      window.location.href = "/login";
    }
  }

  init();
</script>
