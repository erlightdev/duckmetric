---
import AuthLayout from "../layouts/AuthLayout.astro";
---

<AuthLayout title="Sign In - Duckmetric">
  <div class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500/20">
          <svg class="h-8 w-8 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-white">Sign in to Duckmetric</h1>
        <p class="mt-2 text-sm text-neutral-400">
          Don't have an account? <a href="/signup" class="text-white font-medium hover:underline cursor-pointer">Sign up</a>
        </p>
      </div>

      <!-- Step 1: Social + Email -->
      <div id="step-email">
        <div class="space-y-3 mb-6">
          <button id="google-btn" type="button" class="flex w-full items-center justify-center gap-3 rounded-lg border border-neutral-700 bg-neutral-800/50 px-4 py-3 text-sm font-medium text-white hover:bg-neutral-800 transition-colors cursor-pointer">
            <svg class="h-5 w-5" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Sign in with Google
          </button>
          <button id="facebook-btn" type="button" class="flex w-full items-center justify-center gap-3 rounded-lg border border-neutral-700 bg-neutral-800/50 px-4 py-3 text-sm font-medium text-white hover:bg-neutral-800 transition-colors cursor-pointer">
            <svg class="h-5 w-5" fill="#1877F2" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Sign in with Facebook
          </button>
        </div>

        <div class="relative mb-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-neutral-700"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="bg-neutral-950 px-3 text-neutral-500">Or</span>
          </div>
        </div>

        <div class="space-y-3">
          <div>
            <label for="email" class="block text-sm font-medium text-neutral-300 mb-1.5">Enter your email</label>
            <input
              id="email"
              type="email"
              placeholder="name@email.com"
              class="w-full rounded-lg border border-neutral-700 bg-neutral-800/50 px-4 py-3 text-white placeholder-neutral-500 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors"
            />
            <p id="email-error" class="mt-1 text-sm text-red-500 hidden"></p>
          </div>
          <button id="continue-password" type="button" class="w-full rounded-lg border border-neutral-700 bg-neutral-800/50 px-4 py-3 text-sm font-medium text-white hover:bg-neutral-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
            Continue with password
          </button>
          <button id="login-otp" type="button" class="flex w-full items-center justify-center gap-2 rounded-lg border border-neutral-700 bg-neutral-800/50 px-4 py-3 text-sm font-medium text-white hover:bg-neutral-800 transition-colors cursor-pointer">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Log in with OTP
          </button>
        </div>

        <p class="mt-6 text-center text-xs text-neutral-500">
          By signing in, you agree to our <a href="/terms" class="text-white hover:underline cursor-pointer">Terms & Conditions</a> and <a href="/privacy" class="text-white hover:underline cursor-pointer">Privacy Policy</a>.
        </p>
        <p class="mt-3 text-center text-sm text-neutral-400">
          Need help? <a href="/support" class="text-white font-medium hover:underline cursor-pointer">Contact support</a>
        </p>
      </div>

      <!-- Step 2: Password login -->
      <div id="step-password" class="hidden">
        <button id="back-to-email" type="button" class="mb-6 flex items-center gap-1 text-sm text-neutral-400 hover:text-white transition-colors cursor-pointer">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          Back
        </button>
        <h2 class="text-lg font-semibold text-white mb-1">Welcome back</h2>
        <p class="text-sm text-neutral-400 mb-6" id="password-email-display"></p>

        <form id="password-form" class="space-y-4">
          <div>
            <label for="password" class="block text-sm font-medium text-neutral-300 mb-1.5">Password</label>
            <input
              id="password"
              type="password"
              placeholder="Enter your password"
              class="w-full rounded-lg border border-neutral-700 bg-neutral-800/50 px-4 py-3 text-white placeholder-neutral-500 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors"
            />
            <p id="password-error" class="mt-1 text-sm text-red-500 hidden"></p>
          </div>
          <p id="password-form-error" class="text-sm text-red-500 hidden"></p>
          <button type="submit" id="password-submit" class="w-full rounded-lg bg-emerald-600 px-4 py-3 text-sm font-medium text-white hover:bg-emerald-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
            Sign in
          </button>
        </form>
        <p class="mt-4 text-center text-sm">
          <a href="/forgot-password" class="text-neutral-400 hover:text-white transition-colors cursor-pointer">Forgot password?</a>
        </p>
      </div>

      <!-- Step 3: OTP login -->
      <div id="step-otp" class="hidden">
        <button id="back-to-email-otp" type="button" class="mb-6 flex items-center gap-1 text-sm text-neutral-400 hover:text-white transition-colors cursor-pointer">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          Back
        </button>
        <div class="text-center mb-8">
          <h2 class="text-xl font-bold text-white">Enter verification code</h2>
          <p class="mt-2 text-sm text-neutral-400" id="otp-email-display"></p>
        </div>

        <form id="otp-form" class="space-y-6">
          <div class="flex justify-center gap-2">
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
          </div>
          <p id="otp-form-error" class="text-sm text-red-500 text-center hidden"></p>
          <div class="flex justify-center">
            <button type="submit" id="otp-submit" class="w-full max-w-xs rounded-lg bg-emerald-600 px-4 py-3 text-sm font-medium text-white hover:bg-emerald-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
              Verify & log in
            </button>
          </div>
        </form>
        <div class="mt-6 space-y-3 text-center">
          <p class="text-sm text-neutral-400">
            <span id="otp-countdown" class="hidden"></span>
            <button id="resend-otp" type="button" class="text-white hover:underline disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer hidden" disabled>Resend</button>
          </p>
          <p class="text-sm">
            <button id="use-different-method" type="button" class="text-white font-medium hover:underline cursor-pointer">Use a different method</button>
          </p>
        </div>
      </div>
    </div>
  </div>
</AuthLayout>

<script>
  import { authClient } from "../lib/auth-client";
  import { toaster as toast } from "../components/ui/sonner.js";

  const stepEmail = document.getElementById("step-email")!;
  const stepPassword = document.getElementById("step-password")!;
  const stepOtp = document.getElementById("step-otp")!;

  const emailInput = document.getElementById("email") as HTMLInputElement;
  const emailError = document.getElementById("email-error")!;
  const continuePasswordBtn = document.getElementById("continue-password")!;
  const loginOtpBtn = document.getElementById("login-otp")!;
  const googleBtn = document.getElementById("google-btn")!;
  const facebookBtn = document.getElementById("facebook-btn")!;

  const passwordForm = document.getElementById("password-form") as HTMLFormElement;
  const passwordInput = document.getElementById("password") as HTMLInputElement;
  const passwordError = document.getElementById("password-error")!;
  const passwordFormError = document.getElementById("password-form-error")!;
  const passwordSubmit = document.getElementById("password-submit") as HTMLButtonElement;
  const passwordEmailDisplay = document.getElementById("password-email-display")!;
  const backToEmail = document.getElementById("back-to-email")!;

  const otpForm = document.getElementById("otp-form") as HTMLFormElement;
  const otpInputs = document.querySelectorAll(".otp-input") as NodeListOf<HTMLInputElement>;
  const otpFormError = document.getElementById("otp-form-error")!;
  const otpSubmit = document.getElementById("otp-submit") as HTMLButtonElement;
  const otpEmailDisplay = document.getElementById("otp-email-display")!;
  const backToEmailOtp = document.getElementById("back-to-email-otp") ?? document.getElementById("use-different-method")!;
  const resendOtpBtn = document.getElementById("resend-otp") as HTMLButtonElement;
  const otpCountdown = document.getElementById("otp-countdown")!;
  const useDifferentMethod = document.getElementById("use-different-method")!;

  let currentEmail = "";
  let countdownInterval: ReturnType<typeof setInterval> | null = null;

  function getOtpValue(): string {
    return Array.from(otpInputs).map((input) => input.value).join("");
  }

  function setOtpValue(value: string) {
    otpInputs.forEach((input, i) => {
      input.value = value[i] || "";
    });
  }

  function showStep(step: "email" | "password" | "otp") {
    stepEmail.classList.add("hidden");
    stepPassword.classList.add("hidden");
    stepOtp.classList.add("hidden");

    if (step === "email") stepEmail.classList.remove("hidden");
    else if (step === "password") stepPassword.classList.remove("hidden");
    else stepOtp.classList.remove("hidden");
  }

  function validateEmail(email: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  async function checkEmailExists(email: string): Promise<{ exists: boolean; hasPassword: boolean }> {
    try {
      const res = await fetch("/api/check-email", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();
      return { exists: data.exists, hasPassword: data.hasPassword };
    } catch {
      return { exists: false, hasPassword: false };
    }
  }

  function startCountdown() {
    let seconds = 60;
    resendOtpBtn.disabled = true;
    resendOtpBtn.classList.add("hidden");
    otpCountdown.textContent = `Resend in ${seconds}s`;
    otpCountdown.classList.remove("hidden");

    countdownInterval = setInterval(() => {
      seconds--;
      if (seconds <= 0) {
        clearInterval(countdownInterval!);
        resendOtpBtn.disabled = false;
        otpCountdown.classList.add("hidden");
        resendOtpBtn.classList.remove("hidden");
      } else {
        otpCountdown.textContent = `Resend in ${seconds}s`;
      }
    }, 1000);
  }

  // OTP input behavior
  otpInputs.forEach((input, index) => {
    input.addEventListener("input", (e) => {
      const target = e.target as HTMLInputElement;
      target.value = target.value.replace(/[^0-9]/g, "");

      if (target.value && index < otpInputs.length - 1) {
        otpInputs[index + 1].focus();
      }

      if (getOtpValue().length === 6) {
        otpForm.requestSubmit();
      }
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Backspace" && !input.value && index > 0) {
        otpInputs[index - 1].focus();
        otpInputs[index - 1].value = "";
      }
    });

    input.addEventListener("paste", (e) => {
      e.preventDefault();
      const pasted = (e.clipboardData || window.clipboardData).getData("text").replace(/[^0-9]/g, "").slice(0, 6);
      setOtpValue(pasted);
      if (pasted.length > 0) {
        otpInputs[Math.min(pasted.length, otpInputs.length) - 1].focus();
      }
      if (pasted.length === 6) {
        otpForm.requestSubmit();
      }
    });
  });

  continuePasswordBtn.addEventListener("click", async () => {
    emailError.classList.add("hidden");
    if (!validateEmail(emailInput.value)) {
      emailError.textContent = "Please enter a valid email address";
      emailError.classList.remove("hidden");
      return;
    }

    currentEmail = emailInput.value;
    continuePasswordBtn.disabled = true;
    continuePasswordBtn.textContent = "Checking...";

    const { exists, hasPassword } = await checkEmailExists(currentEmail);

    continuePasswordBtn.disabled = false;
    continuePasswordBtn.textContent = "Continue with password";

    if (!exists) {
      toast.error("No account found", {
        description: "This email isn't registered. Sign up to create an account.",
        action: {
          label: "Sign up",
          onClick: () => { window.location.href = "/signup"; },
        },
      });
      return;
    }

    if (!hasPassword) {
      toast.info("No password set", {
        description: "Use 'Log in with OTP' instead.",
      });
      return;
    }

    passwordEmailDisplay.textContent = currentEmail;
    showStep("password");
  });

  loginOtpBtn.addEventListener("click", async () => {
    emailError.classList.add("hidden");
    if (!validateEmail(emailInput.value)) {
      emailError.textContent = "Please enter a valid email address";
      emailError.classList.remove("hidden");
      return;
    }
    currentEmail = emailInput.value;

    loginOtpBtn.disabled = true;
    loginOtpBtn.textContent = "Checking...";

    const { exists } = await checkEmailExists(currentEmail);

    if (!exists) {
      loginOtpBtn.disabled = false;
      loginOtpBtn.innerHTML = `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg> Log in with OTP`;
      toast.error("No account found", {
        description: "No account found with this email. Please sign up first.",
        action: {
          label: "Sign up",
          onClick: () => { window.location.href = "/signup"; },
        },
      });
      return;
    }

    loginOtpBtn.textContent = "Sending code...";

    const { error } = await authClient.emailOtp.sendVerificationOtp({
      email: currentEmail,
      type: "sign-in",
    });

    loginOtpBtn.disabled = false;
    loginOtpBtn.innerHTML = `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg> Log in with OTP`;

    if (error) {
      toast.error("Failed to send code", {
        description: error.message || "Please try again.",
      });
      return;
    }

    toast.success("Code sent", {
      description: `Verification code sent to ${currentEmail}`,
    });

    otpEmailDisplay.textContent = `Enter the 6-digit code sent to ${currentEmail}`;
    showStep("otp");
    otpInputs[0].focus();
    startCountdown();
  });

  googleBtn.addEventListener("click", () => {
    authClient.signIn.social({ provider: "google", callbackURL: "/dashboard" });
  });

  facebookBtn.addEventListener("click", () => {
    authClient.signIn.social({ provider: "facebook", callbackURL: "/dashboard" });
  });

  backToEmail.addEventListener("click", () => showStep("email"));
  backToEmailOtp.addEventListener("click", () => showStep("email"));
  useDifferentMethod.addEventListener("click", () => showStep("email"));

  passwordForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    passwordError.classList.add("hidden");
    passwordFormError.classList.add("hidden");

    if (!passwordInput.value) {
      passwordError.textContent = "Password is required";
      passwordError.classList.remove("hidden");
      return;
    }

    passwordSubmit.disabled = true;
    passwordSubmit.textContent = "Signing in...";

    await authClient.signIn.email(
      { email: currentEmail, password: passwordInput.value },
      {
        onSuccess: () => {
          toast.success("Welcome back!");
          window.location.href = "/dashboard";
        },
        onError: (ctx) => {
          passwordFormError.textContent = ctx.error.message || "Invalid email or password";
          passwordFormError.classList.remove("hidden");
          passwordSubmit.disabled = false;
          passwordSubmit.textContent = "Sign in";
        },
      }
    );
  });

  otpForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    otpFormError.classList.add("hidden");

    const otp = getOtpValue();
    if (otp.length !== 6) {
      otpFormError.textContent = "Please enter the complete 6-digit code";
      otpFormError.classList.remove("hidden");
      return;
    }

    otpSubmit.disabled = true;
    otpSubmit.textContent = "Verifying...";

    const { error } = await authClient.signIn.emailOtp({
      email: currentEmail,
      otp,
    });

    if (error) {
      otpFormError.textContent = error.message || "Invalid or expired code";
      otpFormError.classList.remove("hidden");
      otpSubmit.disabled = false;
      otpSubmit.textContent = "Verify & log in";
      setOtpValue("");
      otpInputs[0].focus();
      return;
    }

    toast.success("Welcome back!");
    window.location.href = "/dashboard";
  });

  resendOtpBtn.addEventListener("click", async () => {
    resendOtpBtn.disabled = true;
    setOtpValue("");
    otpInputs[0].focus();
    const { error } = await authClient.emailOtp.sendVerificationOtp({
      email: currentEmail,
      type: "sign-in",
    });
    if (!error) {
      toast.success("Code resent");
      startCountdown();
    }
  });
</script>
