---
import AuthLayout from "../layouts/AuthLayout.astro";
---

<AuthLayout title="Forgot Password - Duckmetric">
  <div class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500/20">
          <svg class="h-8 w-8 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-white">Reset your password</h1>
        <p class="mt-2 text-sm text-neutral-400">
          Enter your email to receive a reset code
        </p>
      </div>

      <!-- Step 1: Enter email -->
      <div id="step-email">
        <form id="reset-email-form" class="space-y-4">
          <div>
            <label for="reset-email" class="block text-sm font-medium text-neutral-300 mb-1.5">Email address</label>
            <input
              id="reset-email"
              type="email"
              placeholder="name@email.com"
              autocomplete="email"
              class="w-full rounded-lg border border-neutral-700 bg-neutral-800/50 px-4 py-3 text-white placeholder-neutral-500 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors"
            />
            <p id="reset-email-error" class="mt-1 text-sm text-red-500 hidden"></p>
          </div>
          <p id="reset-email-form-error" class="text-sm text-red-500 hidden"></p>
          <button type="submit" id="reset-email-submit" class="w-full rounded-lg bg-emerald-600 px-4 py-3 text-sm font-medium text-white hover:bg-emerald-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
            Send reset code
          </button>
        </form>
        <p class="mt-6 text-center text-sm">
          <a href="/login" class="text-neutral-400 hover:text-white transition-colors cursor-pointer">← Back to sign in</a>
        </p>
      </div>

      <!-- Step 2: Enter OTP -->
      <div id="step-otp" class="hidden">
        <button id="back-to-reset-email" type="button" class="mb-6 flex items-center gap-1 text-sm text-neutral-400 hover:text-white transition-colors cursor-pointer">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          Back
        </button>
        <div class="text-center mb-8">
          <h2 class="text-xl font-bold text-white">Enter verification code</h2>
          <p class="mt-2 text-sm text-neutral-400">Enter the 6-digit code sent to <span id="reset-otp-email-display" class="text-white font-medium"></span></p>
        </div>

        <form id="reset-otp-form" class="space-y-6">
          <div class="flex justify-center gap-2">
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="reset-otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="reset-otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="reset-otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="reset-otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="reset-otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" class="reset-otp-input h-14 w-12 rounded-lg border border-neutral-700 bg-neutral-800/50 text-center text-xl font-semibold text-white focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors" />
          </div>
          <p id="reset-otp-form-error" class="text-sm text-red-500 text-center hidden"></p>
          <div class="flex justify-center">
            <button type="submit" id="reset-otp-submit" class="w-full max-w-xs rounded-lg bg-emerald-600 px-4 py-3 text-sm font-medium text-white hover:bg-emerald-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
              Verify code
            </button>
          </div>
        </form>
        <div class="mt-6 space-y-3 text-center">
          <p class="text-sm text-neutral-400">
            <span id="reset-countdown" class="hidden"></span>
            <button id="resend-reset-otp" type="button" class="text-white hover:underline disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer hidden" disabled>Resend</button>
          </p>
        </div>
      </div>

      <!-- Step 3: New password -->
      <div id="step-new-password" class="hidden">
        <button id="back-to-reset-otp" type="button" class="mb-6 flex items-center gap-1 text-sm text-neutral-400 hover:text-white transition-colors cursor-pointer">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          Back
        </button>
        <h2 class="text-lg font-semibold text-white mb-1">Set new password</h2>
        <p class="text-sm text-neutral-400 mb-6">Choose a strong password for your account</p>

        <form id="new-password-form" class="space-y-4">
          <div>
            <label for="reset-new-password" class="block text-sm font-medium text-neutral-300 mb-1.5">New password</label>
            <input
              id="reset-new-password"
              type="password"
              placeholder="At least 8 characters"
              minlength="8"
              autocomplete="new-password"
              class="w-full rounded-lg border border-neutral-700 bg-neutral-800/50 px-4 py-3 text-white placeholder-neutral-500 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors"
            />
            <p id="reset-new-password-error" class="mt-1 text-sm text-red-500 hidden"></p>
          </div>
          <div>
            <label for="reset-confirm-password" class="block text-sm font-medium text-neutral-300 mb-1.5">Confirm password</label>
            <input
              id="reset-confirm-password"
              type="password"
              placeholder="Confirm your password"
              autocomplete="new-password"
              class="w-full rounded-lg border border-neutral-700 bg-neutral-800/50 px-4 py-3 text-white placeholder-neutral-500 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-colors"
            />
            <p id="reset-confirm-password-error" class="mt-1 text-sm text-red-500 hidden"></p>
          </div>
          <p id="reset-password-form-error" class="text-sm text-red-500 hidden"></p>
          <button type="submit" id="reset-password-submit" class="w-full rounded-lg bg-emerald-600 px-4 py-3 text-sm font-medium text-white hover:bg-emerald-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer">
            Reset password
          </button>
        </form>
      </div>

      <!-- Success -->
      <div id="step-success" class="hidden text-center">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500/20">
          <svg class="h-8 w-8 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-white mb-2">Password reset successfully</h2>
        <p class="text-sm text-neutral-400 mb-6">You can now sign in with your new password</p>
        <a href="/login" class="inline-block w-full rounded-lg bg-emerald-600 px-4 py-3 text-sm font-medium text-white text-center hover:bg-emerald-700 transition-colors cursor-pointer">
          Sign in
        </a>
      </div>
    </div>
  </div>
</AuthLayout>

<script>
  import { authClient } from "../lib/auth-client";
  import { toaster as toast } from "../components/ui/sonner.js";

  let resetEmail = "";
  let resetOtp = "";
  let countdownInterval: ReturnType<typeof setInterval> | null = null;

  function showStep(step: "email" | "otp" | "new-password" | "success") {
    document.getElementById("step-email")!.classList.add("hidden");
    document.getElementById("step-otp")!.classList.add("hidden");
    document.getElementById("step-new-password")!.classList.add("hidden");
    document.getElementById("step-success")!.classList.add("hidden");
    document.getElementById(`step-${step}`)!.classList.remove("hidden");
  }

  function validateEmail(email: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  function startCountdown() {
    let seconds = 60;
    const resendBtn = document.getElementById("resend-reset-otp") as HTMLButtonElement;
    const countdown = document.getElementById("reset-countdown")!;
    resendBtn.disabled = true;
    countdown.textContent = `Resend in ${seconds}s`;
    countdown.classList.remove("hidden");
    resendBtn.classList.add("hidden");

    countdownInterval = setInterval(() => {
      seconds--;
      if (seconds <= 0) {
        clearInterval(countdownInterval!);
        resendBtn.disabled = false;
        countdown.classList.add("hidden");
        resendBtn.classList.remove("hidden");
      } else {
        countdown.textContent = `Resend in ${seconds}s`;
      }
    }, 1000);
  }

  // Step 1: Email
  const resetEmailForm = document.getElementById("reset-email-form") as HTMLFormElement;
  const resetEmailInput = document.getElementById("reset-email") as HTMLInputElement;
  const resetEmailError = document.getElementById("reset-email-error")!;
  const resetEmailFormError = document.getElementById("reset-email-form-error")!;
  const resetEmailSubmit = document.getElementById("reset-email-submit") as HTMLButtonElement;

  async function checkEmailExists(email: string): Promise<{ exists: boolean }> {
    try {
      const res = await fetch("/api/check-email", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();
      return { exists: data.exists };
    } catch {
      return { exists: false };
    }
  }

  resetEmailForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    resetEmailError.classList.add("hidden");
    resetEmailFormError.classList.add("hidden");

    const email = resetEmailInput.value.trim();
    if (!validateEmail(email)) {
      resetEmailError.textContent = "Please enter a valid email address";
      resetEmailError.classList.remove("hidden");
      return;
    }

    resetEmailSubmit.disabled = true;
    resetEmailSubmit.textContent = "Checking...";

    const { exists } = await checkEmailExists(email);

    if (!exists) {
      resetEmailSubmit.disabled = false;
      resetEmailSubmit.textContent = "Send reset code";
      toast.error("No account found", {
        description: "No account found with this email. Please sign up first.",
        action: {
          label: "Sign up",
          onClick: () => { window.location.href = "/signup"; },
        },
      });
      return;
    }

    resetEmailSubmit.textContent = "Sending code...";

    resetEmail = email;
    const { error } = await authClient.emailOtp.requestPasswordReset({ email });

    resetEmailSubmit.disabled = false;
    resetEmailSubmit.textContent = "Send reset code";

    if (error) {
      resetEmailFormError.textContent = error.message || "Failed to send reset code";
      resetEmailFormError.classList.remove("hidden");
      return;
    }

    toast.success("Code sent", {
      description: `Password reset code sent to ${email}`,
    });

    document.getElementById("reset-otp-email-display")!.textContent = email;
    showStep("otp");
    startCountdown();
  });

  // Step 2: OTP
  const resetOtpForm = document.getElementById("reset-otp-form") as HTMLFormElement;
  const resetOtpInputs = document.querySelectorAll(".reset-otp-input") as NodeListOf<HTMLInputElement>;
  const resetOtpFormError = document.getElementById("reset-otp-form-error")!;
  const resetOtpSubmit = document.getElementById("reset-otp-submit") as HTMLButtonElement;
  const backToResetEmail = document.getElementById("back-to-reset-email")!;
  const resendResetOtp = document.getElementById("resend-reset-otp") as HTMLButtonElement;

  function getResetOtpValue(): string {
    return Array.from(resetOtpInputs).map((input) => input.value).join("");
  }

  function setResetOtpValue(value: string) {
    resetOtpInputs.forEach((input, i) => {
      input.value = value[i] || "";
    });
  }

  backToResetEmail.addEventListener("click", () => showStep("email"));

  resetOtpInputs.forEach((input, index) => {
    input.addEventListener("input", () => {
      const target = input;
      target.value = target.value.replace(/[^0-9]/g, "");

      if (target.value && index < resetOtpInputs.length - 1) {
        resetOtpInputs[index + 1].focus();
      }

      if (getResetOtpValue().length === 6) {
        resetOtpForm.requestSubmit();
      }
    });

    input.addEventListener("keydown", (e) => {
      if (e.key === "Backspace" && !input.value && index > 0) {
        resetOtpInputs[index - 1].focus();
        resetOtpInputs[index - 1].value = "";
      }
    });

    input.addEventListener("paste", (e) => {
      e.preventDefault();
      const pasted = (e.clipboardData || window.clipboardData).getData("text").replace(/[^0-9]/g, "").slice(0, 6);
      setResetOtpValue(pasted);
      if (pasted.length > 0) {
        resetOtpInputs[Math.min(pasted.length, resetOtpInputs.length) - 1].focus();
      }
      if (pasted.length === 6) {
        resetOtpForm.requestSubmit();
      }
    });
  });

  resetOtpForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    resetOtpFormError.classList.add("hidden");

    const otp = getResetOtpValue();
    if (otp.length !== 6) {
      resetOtpFormError.textContent = "Please enter the complete 6-digit code";
      resetOtpFormError.classList.remove("hidden");
      return;
    }

    resetOtpSubmit.disabled = true;
    resetOtpSubmit.textContent = "Verifying...";

    const { error } = await authClient.emailOtp.checkVerificationOtp({
      email: resetEmail,
      type: "forget-password",
      otp,
    });

    if (error) {
      resetOtpFormError.textContent = error.message || "Invalid or expired code";
      resetOtpFormError.classList.remove("hidden");
      resetOtpSubmit.disabled = false;
      resetOtpSubmit.textContent = "Verify code";
      setResetOtpValue("");
      resetOtpInputs[0].focus();
      return;
    }

    toast.success("Code verified!");
    resetOtp = otp;
    showStep("new-password");
  });

  resendResetOtp.addEventListener("click", async () => {
    resendResetOtp.disabled = true;
    const { error } = await authClient.emailOtp.requestPasswordReset({ email: resetEmail });
    if (!error) {
      toast.success("Code resent");
      startCountdown();
    }
  });

  // Step 3: New password
  const newPasswordForm = document.getElementById("new-password-form") as HTMLFormElement;
  const resetNewPasswordInput = document.getElementById("reset-new-password") as HTMLInputElement;
  const resetConfirmPasswordInput = document.getElementById("reset-confirm-password") as HTMLInputElement;
  const resetNewPasswordError = document.getElementById("reset-new-password-error")!;
  const resetConfirmPasswordError = document.getElementById("reset-confirm-password-error")!;
  const resetPasswordFormError = document.getElementById("reset-password-form-error")!;
  const resetPasswordSubmit = document.getElementById("reset-password-submit") as HTMLButtonElement;
  const backToResetOtp = document.getElementById("back-to-reset-otp")!;

  backToResetOtp.addEventListener("click", () => showStep("otp"));

  newPasswordForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    resetNewPasswordError.classList.add("hidden");
    resetConfirmPasswordError.classList.add("hidden");
    resetPasswordFormError.classList.add("hidden");

    const password = resetNewPasswordInput.value;
    const confirm = resetConfirmPasswordInput.value;

    if (password.length < 8) {
      resetNewPasswordError.textContent = "Password must be at least 8 characters";
      resetNewPasswordError.classList.remove("hidden");
      return;
    }

    if (password !== confirm) {
      resetConfirmPasswordError.textContent = "Passwords do not match";
      resetConfirmPasswordError.classList.remove("hidden");
      return;
    }

    resetPasswordSubmit.disabled = true;
    resetPasswordSubmit.textContent = "Resetting...";

    const { error } = await authClient.emailOtp.resetPassword({
      email: resetEmail,
      otp: resetOtp,
      password,
    });

    if (error) {
      resetPasswordFormError.textContent = error.message || "Failed to reset password";
      resetPasswordFormError.classList.remove("hidden");
      resetPasswordSubmit.disabled = false;
      resetPasswordSubmit.textContent = "Reset password";
      return;
    }

    toast.success("Password reset successfully!");
    showStep("success");
  });
</script>
