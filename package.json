{
	"name": "duckmetric",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^6",
			"@types/node": "^22.13.14",
			"@prisma/client": "^7.8.0",
			"@orpc/server": "^1.13.14",
			"@orpc/client": "^1.13.14",
			"@orpc/openapi": "^1.13.14",
			"@orpc/zod": "^1.13.14",
			"better-auth": "1.6.11"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"db:push": "turbo -F @duckmetric/db db:push",
		"db:studio": "turbo -F @duckmetric/db db:studio",
		"db:generate": "turbo -F @duckmetric/db db:generate",
		"db:migrate": "turbo -F @duckmetric/db db:migrate",
		"db:start": "turbo -F @duckmetric/db db:start",
		"db:watch": "turbo -F @duckmetric/db db:watch",
		"db:stop": "turbo -F @duckmetric/db db:stop",
		"db:down": "turbo -F @duckmetric/db db:down",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@duckmetric/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@duckmetric/config": "workspace:*",
		"@types/node": "catalog:",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.14"
}
